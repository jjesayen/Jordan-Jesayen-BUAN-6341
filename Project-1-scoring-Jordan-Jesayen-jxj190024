    Run this after you complete project_1_scoring and save the required
    artifacts. Validate both model families before submission:

        validate_scoring_function("sklearn")
        validate_scoring_function("h2o")
    """
    print(f"Loading holdout-format dataset from {HOLDOUT_FORMAT_PATH}...")
    holdout_data = pd.read_csv(HOLDOUT_FORMAT_PATH)

    if "MIS_Status" in holdout_data.columns:
        raise AssertionError("Holdout-format scoring input must not include MIS_Status.")

    print(f"Running scoring function for model_type={model_type!r}...")
    predictions = project_1_scoring(holdout_data, model_type=model_type)

    print("Validating output format...")
    validate_scoring_output(predictions, expected_rows=len(holdout_data))

    print(f"Scoring validation passed for model_type={model_type!r}.")
    return predictions


