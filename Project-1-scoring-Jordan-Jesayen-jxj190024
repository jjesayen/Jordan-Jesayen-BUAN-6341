def validate_scoring_output(predictions, expected_rows):
    """Validate the required Project 1 scoring output schema."""
    assert isinstance(predictions, pd.DataFrame), "Output must be a DataFrame."
    assert list(predictions.columns) == REQUIRED_OUTPUT_COLUMNS, (
        "Output columns must be exactly: "
        + ", ".join(REQUIRED_OUTPUT_COLUMNS)
    )
    assert len(predictions) == expected_rows, "Output row count must match input rows."
    assert predictions["label"].isin([0, 1]).all(), "Labels must be 0 or 1."
    assert pd.api.types.is_numeric_dtype(predictions["probability_0"]), (
        "probability_0 must be numeric."
    )
    assert pd.api.types.is_numeric_dtype(predictions["probability_1"]), (
        "probability_1 must be numeric."
    )
    probability_sum_error = (
        predictions["probability_0"] + predictions["probability_1"] - 1.0
    ).abs().max()
    assert probability_sum_error < 1e-6, "Probabilities must sum to 1."


def validate_scoring_function(model_type="sklearn"):
